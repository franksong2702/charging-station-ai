# PostgreSQL 数据库配置
DATABASE_URL=postgresql://user:password@host:port/database
# 或者分别配置
PGDATABASE=postgres
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here

# 邮件配置（可选）
EMAIL_RECIPIENT=service@example.com
EMAIL_RECIPIENT_NAME=客服团队

# Coze API（客服工作流）
COZE_API_TOKEN=your_workflow_api_token_here
COZE_WORKFLOW_API=https://wp5bsz5qfm.coze.site/run

# AI User Agent（测试项目）
AI_USER_AGENT_TOKEN=your_ai_user_agent_token_here
AI_USER_AGENT_API=https://jr9h465hzr.coze.site/stream_run
