# PostgreSQL 数据库配置
DATABASE_URL=postgresql://user:password@host:port/database
# 或者分别配置
PGDATABASE=postgres
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here

# 邮件配置（可选）
EMAIL_RECIPIENT=service@example.com
EMAIL_RECIPIENT_NAME=客服团队

# Coze API（客服工作流）
COZE_API_TOKEN=your_workflow_api_token_here
COZE_WORKFLOW_API=https://wp5bsz5qfm.coze.site/run

# AI User Agent（测试项目）
AI_USER_AGENT_TOKEN=your_ai_user_agent_token_here
AI_USER_AGENT_API=https://jr9h465hzr.coze.site/stream_run
AI_USER_AGENT_PROJECT_ID=7627835614766841865

# 测试邮箱拉取与校验（用于集成测试报告补充兜底邮件原文）
ENABLE_EMAIL_CHECK=true
TEST_EMAIL_IMAP_HOST=imap.qq.com
TEST_EMAIL_IMAP_PORT=993
TEST_EMAIL_IMAP_USERNAME=your_test_mail_account@qq.com
TEST_EMAIL_IMAP_PASSWORD=your_test_mail_auth_code
TEST_EMAIL_IMAP_MAILBOX=INBOX
TEST_EMAIL_SENDER_FILTER=
TEST_EMAIL_SUBJECT_KEYWORD=【充电桩客服】用户问题反馈
TEST_EMAIL_POLL_SECONDS=60
TEST_EMAIL_MAX_SCAN=80
TEST_EMAIL_LOOKBACK_MINUTES=60
REQUIRE_EMAIL_CHECK=true
